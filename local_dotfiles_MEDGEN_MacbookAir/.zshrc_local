# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/opt/miniconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/miniconda3/etc/profile.d/conda.sh" ]; then
        . "/opt/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="/opt/miniconda3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

export PATH="$HOME/.local/bin:$PATH"

# Establish background SSH tunnel to an HPC host (use any alias from ~/.ssh/config).
# Run this when the tmux prefix+Ctrl+c pbcopy_to_local trick stops working (tunnel
# dropped after 24h ControlPersist expiry or network disruption). e.g. tun midway
tun() { ssh -fN "$1"; }
