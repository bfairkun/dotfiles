#!/bin/bash

## USAGE
## start_agent_kernel [--env ENV] [--mem MEM] [--time TIME] [--cpus N] [--lang python|r] [--account ACCOUNT]
##
## Submit a Jupyter kernel as a Slurm job on UMich Great Lakes.
## Once running, tell the Claude Code agent:
##   "connect to compute kernel"       (Python)
##   "connect to compute R kernel"     (R)
##
## Defaults: --env py_general  --mem 48G  --time 4:00:00  --cpus 4  --lang python
##
## To find your SLURM account name, run: my_accounts
## Great Lakes partitions: standard, largemem, gpu, debug

ENV="py_general"
MEM="48G"
TIME="4:00:00"
CPUS=4
LANG="python"
ACCOUNT=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --env)     ENV="$2";     shift 2 ;;
        --mem)     MEM="$2";     shift 2 ;;
        --time)    TIME="$2";    shift 2 ;;
        --cpus)    CPUS="$2";    shift 2 ;;
        --lang)    LANG="$2";    shift 2 ;;
        --account) ACCOUNT="$2"; shift 2 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# Default partition on Great Lakes is "standard".
# Use "largemem" for jobs needing >192GB RAM.
PARTITION="standard"
ACCOUNT_FLAG=""
if [ -n "$ACCOUNT" ]; then
    ACCOUNT_FLAG="--account=$ACCOUNT"
fi

# $SCRATCH is set by the cluster to /scratch/$USER
[ -z "$SCRATCH" ] && SCRATCH="/scratch/$USER"
mkdir -p $SCRATCH/$USER

LOG=$SCRATCH/$USER/agent_kernel.log
CF=$SCRATCH/$USER/agent_kernel.json
[[ "$LANG" == "r" ]] && CF=$SCRATCH/$USER/agent_r_kernel.json

# Remove stale connection file so we can detect when the new kernel is ready
rm -f $CF

SCRIPT=$(dirname $0)/agent_kernel.sbatch

echo "Submitting kernel job (lang=$LANG, env=$ENV, mem=$MEM, time=$TIME, cpus=$CPUS, partition=$PARTITION)..."
[ -n "$ACCOUNT" ] && echo "  SLURM account: $ACCOUNT"

JOBID=$(sbatch --parsable \
    --partition=$PARTITION $ACCOUNT_FLAG \
    --mem=$MEM --time=$TIME --cpus-per-task=$CPUS \
    --output=$LOG \
    $SCRIPT $ENV $LANG)

echo "Job $JOBID submitted. Waiting for kernel to start..."

# Poll until connection file appears (kernel is ready)
while [[ ! -f $CF ]]; do
    sleep 2
done

echo ""
echo "Kernel ready! Connection file: $CF"
echo ""
echo "Tell the Claude Code agent:"
if [[ "$LANG" == "r" ]]; then
    echo "  'connect to compute R kernel'"
else
    echo "  'connect to compute kernel'"
fi
