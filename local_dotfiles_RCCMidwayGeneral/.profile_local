# .profile_local for RCC Midway
# Added myself, don't know why the conda blocks managed by conda init aren't
# working right.

echo "Running  ${0}..."
# set -x

export TZ='America/Chicago'
# export PATH="/home/bjf79/miniconda3/bin:$PATH"

export PATH=$PATH:~/scripts
# export PATH=$PATH:~/software
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.npm-global/bin:$PATH"

# Ensure TMPDIR is /tmp so ssh-agent sockets don't land in $HOME
export TMPDIR='/tmp'

# Source ssh settings or start ssh agent if not already running
# Useful for ssh keys for git for example
mkdir -p $HOME/.ssh
SSH_ENV="$HOME/.ssh/agent-environment"

function start_agent {
    echo "Initialising new SSH agent..."
    /usr/bin/ssh-agent | sed 's/^echo/#echo/' > "${SSH_ENV}"
    echo succeeded
    chmod 600 "${SSH_ENV}"
    . "${SSH_ENV}" > /dev/null
    /usr/bin/ssh-add;
}

# Source SSH settings, if applicable

if [ -f "${SSH_ENV}" ]; then . "${SSH_ENV}" > /dev/null
    #ps ${SSH_AGENT_PID} doesn't work under cywgin
    ps -ef | grep ${SSH_AGENT_PID} | grep ssh-agent$ > /dev/null || {
        start_agent;
    }
else
    start_agent;
fi


# Midway2 specific stuff
hostname | grep -q 'midway2'
if [ $? -eq 0 ]; then
    module unload gsl
    module load mosh
    module load gsl/2.5
    # module load rstudio
    module load netcat #useful to copy to local clipboard
    module load vim/8.1
    module load tmux/3.1c
fi

# Midway3 specific stuff
hostname | grep -q 'midway3'
if [ $? -eq 0 ]; then
    module load mosh
    # module load rstudio
    module load tmux
fi


# Attach or tmux session
if [[ -z "$TMUX" && -n "$SSH_CONNECTION" && "$-" == *i* ]]; then
    tmux attach-session -t ssh_tmux || tmux new-session -s ssh_tmux
fi

# Ensure dispatcher watchdog cron job is registered.
# Idempotent — only adds the entry if missing. Self-heals if crontab is wiped.
if [ -f ~/.claude/dispatcher_watchdog.sh ]; then
    if ! crontab -l 2>/dev/null | grep -q "dispatcher_watchdog.sh"; then
        (crontab -l 2>/dev/null; echo "*/5 * * * * $HOME/.claude/dispatcher_watchdog.sh") | crontab -
    fi
fi
