#!/usr/bin/env python3
"""
render_notebook — transparent shim over `quarto` that records the render
environment (host, scheduler allocation, actual peak memory, conda env, etc.)
into a hidden, non-rendering block at the end of the .qmd file.

Usage mirrors the quarto CLI exactly — just swap `quarto` for `render_notebook`:
    render_notebook render notebook.qmd
    render_notebook render notebook.qmd --to pdf --output-dir out/

All arguments are passed through to `quarto` untouched. After a successful
render, if exactly one existing .qmd file is found among the args, a managed
`::: {.content-hidden}` block is inserted/updated at the end of that file.

Portability notes:
  - Stdlib only. No HPC/Slurm assumptions — every field degrades gracefully.
  - Peak memory is the *actual* RSS of the render child processes, measured via
    resource.getrusage(RUSAGE_CHILDREN) — works on Linux/macOS, skipped elsewhere.
  - Only renders that go *through* this wrapper get tagged. `quarto preview`,
    VS Code's render button, etc. are not captured (degrades to no block).
  - A patch failure (read-only file, etc.) never changes quarto's exit code.
"""

import os
import re
import socket
import subprocess
import sys
import time
from datetime import datetime

MARKER = "### render-env (auto-generated by render_notebook — do not edit)"
# Matches the whole managed content-hidden block for idempotent replacement.
BLOCK_RE = re.compile(
    r"(?ms)^::: \{\.content-hidden\}\n" + re.escape(MARKER) + r".*?^:::[ \t]*$\n?"
)


def human_mb(mb):
    """Format a value in MB as a human string (e.g. 48G, 512M)."""
    try:
        mb = float(mb)
    except (TypeError, ValueError):
        return None
    if mb >= 1024:
        g = mb / 1024
        return f"{g:.0f}G" if g == int(g) else f"{g:.1f}G"
    return f"{mb:.0f}M"


def human_kb(kb):
    """Format a value in KB as a human string."""
    if kb is None:
        return None
    return human_mb(kb / 1024)


def detect_conda_env():
    env = os.environ.get("CONDA_DEFAULT_ENV")
    if env:
        return env
    venv = os.environ.get("VIRTUAL_ENV")
    if venv:
        return f"venv:{os.path.basename(venv)}"
    return os.path.basename(sys.prefix)


def detect_mem_allocated():
    """Slurm allocated memory as a human string, or None if not under Slurm."""
    per_node = os.environ.get("SLURM_MEM_PER_NODE")  # MB
    if per_node:
        return human_mb(per_node)
    per_cpu = os.environ.get("SLURM_MEM_PER_CPU")  # MB
    cpus = os.environ.get("SLURM_CPUS_ON_NODE") or os.environ.get("SLURM_CPUS_PER_TASK")
    if per_cpu and cpus:
        try:
            return human_mb(float(per_cpu) * int(cpus))
        except ValueError:
            return human_mb(per_cpu)
    return None


def detect_node_type():
    if os.environ.get("SLURM_JOB_ID"):
        return "compute"
    if "login" in socket.gethostname().lower():
        return "login"
    return "local"


def quarto_version():
    try:
        out = subprocess.run(
            ["quarto", "--version"], capture_output=True, text=True, timeout=15
        )
        return out.stdout.strip() or None
    except Exception:
        return None


def collect_env(args, elapsed_sec, peak_rss_kb):
    """Build the ordered list of (key, value) fields, omitting empty ones."""
    fields = []

    def add(key, value):
        if value is not None and value != "":
            fields.append((key, str(value)))

    add("last_rendered", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
    add("host", socket.gethostname())
    add("node_type", detect_node_type())
    add("scheduler", "slurm" if os.environ.get("SLURM_JOB_ID") else "none")
    add("slurm_job_id", os.environ.get("SLURM_JOB_ID"))
    add("partition", os.environ.get("SLURM_JOB_PARTITION"))
    add("cpus_allocated",
        os.environ.get("SLURM_CPUS_ON_NODE") or os.environ.get("SLURM_CPUS_PER_TASK"))
    add("mem_allocated", detect_mem_allocated())
    add("cpus_available", os.cpu_count())
    add("peak_rss", human_kb(peak_rss_kb))
    add("conda_env", detect_conda_env())
    add("quarto_version", quarto_version())
    add("render_args", " ".join(args))
    add("elapsed", f"{elapsed_sec:.0f}s")
    return fields


def render_block(fields):
    lines = ["::: {.content-hidden}", MARKER, ""]
    lines += [f"- {k}: {v}" for k, v in fields]
    lines += [":::", ""]
    return "\n".join(lines)


def patch_qmd(qmd_path, block):
    """Insert or replace the managed block at the end of the .qmd file."""
    try:
        with open(qmd_path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError as e:
        print(f"[render_notebook] could not read {qmd_path}: {e}", file=sys.stderr)
        return

    if BLOCK_RE.search(text):
        new_text = BLOCK_RE.sub(block + "\n", text)
    else:
        sep = "" if text.endswith("\n\n") else ("\n" if text.endswith("\n") else "\n\n")
        new_text = text + sep + block + "\n"

    if new_text == text:
        return
    try:
        with open(qmd_path, "w", encoding="utf-8") as f:
            f.write(new_text)
        print(f"[render_notebook] updated render-env block in {qmd_path}")
    except OSError as e:
        print(f"[render_notebook] could not write {qmd_path}: {e}", file=sys.stderr)


def find_single_qmd(args):
    qmds = [a for a in args if a.endswith(".qmd") and os.path.isfile(a)]
    return qmds


HELP = """\
render_notebook — transparent shim over `quarto` that records the render
environment into a hidden, non-rendering block at the end of the .qmd.

USAGE
  Use it exactly like the quarto CLI — just swap `quarto` for `render_notebook`:
    render_notebook render notebook.qmd
    render_notebook render notebook.qmd --to pdf --output-dir out/

  All args pass straight through to quarto. After a successful render, if exactly
  one existing .qmd is among the args, a managed `::: {.content-hidden}` block is
  inserted/updated at its end (invisible in output, persists in the source).

CAPTURED FIELDS
  last_rendered, host, node_type (compute/login/local), scheduler, slurm_job_id,
  partition, cpus_allocated, mem_allocated (Slurm grant), cpus_available,
  peak_rss (ACTUAL measured peak memory of the render), conda_env,
  quarto_version, render_args, elapsed.

  Use peak_rss to size the minimum memory for a re-render; mem_allocated is only
  what Slurm happened to grant. Read an existing notebook's block with:
    grep -A20 'render-env (auto-generated' notebook.qmd

NOTES
  - Only renders going through this wrapper are tagged (not `quarto preview`/IDE).
  - Block is written only on a successful (exit 0) render with a single .qmd.
  - A patch failure never changes quarto's exit code.
  - `render_notebook -h` shows this help; `render_notebook render nb.qmd --help`
    passes through to quarto's own help.
"""


def main():
    args = sys.argv[1:]
    if not args:
        print("usage: render_notebook <quarto args>   "
              "(e.g. render_notebook render notebook.qmd --to html)", file=sys.stderr)
        return 2

    if args[0] in ("-h", "--help"):
        print(HELP)
        return 0

    start = time.time()
    try:
        result = subprocess.run(["quarto"] + args)
    except FileNotFoundError:
        print("[render_notebook] quarto not found on PATH", file=sys.stderr)
        return 127
    elapsed = time.time() - start
    rc = result.returncode

    # Peak RSS of the render child processes (Linux: KB, macOS: bytes).
    peak_rss_kb = None
    try:
        import resource
        ru = resource.getrusage(resource.RUSAGE_CHILDREN).ru_maxrss
        if ru > 0:
            peak_rss_kb = ru if sys.platform != "darwin" else ru / 1024
    except Exception:
        pass

    # Only patch on success, and only when exactly one .qmd is unambiguous.
    if rc == 0:
        qmds = find_single_qmd(args)
        if len(qmds) == 1:
            fields = collect_env(args, elapsed, peak_rss_kb)
            patch_qmd(qmds[0], render_block(fields))
        elif len(qmds) == 0:
            print("[render_notebook] no single .qmd in args — skipping env block.")
        else:
            print(f"[render_notebook] multiple .qmd files {qmds} — skipping env block.")

    return rc


if __name__ == "__main__":
    sys.exit(main())
