#!/usr/bin/env python3
"""
render_notebook — transparent shim over `quarto` that records the render
environment (host, scheduler allocation, actual peak memory, conda env, etc.)
into a visible block.

Two stats blocks can appear, and they intentionally say different things:
  - A block appended to the .qmd SOURCE, describing the PREVIOUS render. This
    is unavoidable: a render's own elapsed time/peak memory aren't known until
    quarto has already finished reading the source and producing output, so a
    render can never report on itself via the source file.
  - For HTML output specifically, a second block is injected directly into the
    already-generated HTML file (not the source) after quarto exits, and DOES
    describe the render that just produced that exact file. This works because
    it's plain text editing of a finished artifact, not a second quarto pass.

Usage mirrors the quarto CLI exactly — just swap `quarto` for `render_notebook`:
    render_notebook render notebook.qmd
    render_notebook render notebook.qmd --to pdf --output-dir out/

All arguments are passed through to `quarto` untouched. quarto's stdout/stderr
still stream live to the terminal as it runs (nothing about progress visibility
changes) while also being captured to find the `Output created: <path>` line
quarto prints on success.

Portability notes:
  - Stdlib only. No HPC/Slurm assumptions — every field degrades gracefully.
  - Peak memory is the *actual* RSS of the render child processes, measured via
    resource.getrusage(RUSAGE_CHILDREN) — works on Linux/macOS, skipped elsewhere.
  - Only renders that go *through* this wrapper get tagged. `quarto preview`,
    VS Code's render button, etc. are not captured (degrades to no block).
  - A patch failure (read-only file, etc.) never changes quarto's exit code.
"""

import os
import re
import socket
import subprocess
import sys
import time
from datetime import datetime

MARKER = "### render-env (auto-generated by render_notebook — reflects the PREVIOUS render; do not edit)"
# Matches the whole managed block (always appended last, so matching to EOF is safe)
# for idempotent replacement.
BLOCK_RE = re.compile(r"(?ms)^---\n\n" + re.escape(MARKER) + r"\n\n.*\Z")

HTML_MARKER = "render-env (auto-generated by render_notebook — accurate for THIS render)"
HTML_BLOCK_RE = re.compile(
    r"(?s)<!-- render-env:start -->.*?<!-- render-env:end -->\n?"
)


def human_mb(mb):
    """Format a value in MB as a human string (e.g. 48G, 512M)."""
    try:
        mb = float(mb)
    except (TypeError, ValueError):
        return None
    if mb >= 1024:
        g = mb / 1024
        return f"{g:.0f}G" if g == int(g) else f"{g:.1f}G"
    return f"{mb:.0f}M"


def human_kb(kb):
    """Format a value in KB as a human string."""
    if kb is None:
        return None
    return human_mb(kb / 1024)


def detect_conda_env():
    env = os.environ.get("CONDA_DEFAULT_ENV")
    if env:
        return env
    venv = os.environ.get("VIRTUAL_ENV")
    if venv:
        return f"venv:{os.path.basename(venv)}"
    return os.path.basename(sys.prefix)


def detect_mem_allocated():
    """Slurm allocated memory as a human string, or None if not under Slurm."""
    per_node = os.environ.get("SLURM_MEM_PER_NODE")  # MB
    if per_node:
        return human_mb(per_node)
    per_cpu = os.environ.get("SLURM_MEM_PER_CPU")  # MB
    cpus = os.environ.get("SLURM_CPUS_ON_NODE") or os.environ.get("SLURM_CPUS_PER_TASK")
    if per_cpu and cpus:
        try:
            return human_mb(float(per_cpu) * int(cpus))
        except ValueError:
            return human_mb(per_cpu)
    return None


def detect_node_type():
    if os.environ.get("SLURM_JOB_ID"):
        return "compute"
    if "login" in socket.gethostname().lower():
        return "login"
    return "local"


def quarto_version():
    try:
        out = subprocess.run(
            ["quarto", "--version"], capture_output=True, text=True, timeout=15
        )
        return out.stdout.strip() or None
    except Exception:
        return None


def collect_env(args, elapsed_sec, peak_rss_kb):
    """Build the ordered list of (key, value) fields, omitting empty ones."""
    fields = []

    def add(key, value):
        if value is not None and value != "":
            fields.append((key, str(value)))

    add("last_rendered", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
    add("host", socket.gethostname())
    add("node_type", detect_node_type())
    add("scheduler", "slurm" if os.environ.get("SLURM_JOB_ID") else "none")
    add("slurm_job_id", os.environ.get("SLURM_JOB_ID"))
    add("partition", os.environ.get("SLURM_JOB_PARTITION"))
    add("cpus_allocated",
        os.environ.get("SLURM_CPUS_ON_NODE") or os.environ.get("SLURM_CPUS_PER_TASK"))
    add("mem_allocated", detect_mem_allocated())
    add("cpus_available", os.cpu_count())
    add("peak_rss", human_kb(peak_rss_kb))
    add("conda_env", detect_conda_env())
    add("quarto_version", quarto_version())
    add("render_args", " ".join(args))
    add("elapsed", f"{elapsed_sec:.0f}s")
    return fields


def render_block(fields):
    lines = ["---", "", MARKER, ""]
    lines += [f"- {k}: {v}" for k, v in fields]
    lines += [""]
    return "\n".join(lines)


def patch_qmd(qmd_path, block):
    """Insert or replace the managed block at the end of the .qmd file."""
    try:
        with open(qmd_path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError as e:
        print(f"[render_notebook] could not read {qmd_path}: {e}", file=sys.stderr)
        return

    if BLOCK_RE.search(text):
        new_text = BLOCK_RE.sub(block + "\n", text)
    else:
        sep = "" if text.endswith("\n\n") else ("\n" if text.endswith("\n") else "\n\n")
        new_text = text + sep + block + "\n"

    if new_text == text:
        return
    try:
        with open(qmd_path, "w", encoding="utf-8") as f:
            f.write(new_text)
        print(f"[render_notebook] updated render-env block in {qmd_path}")
    except OSError as e:
        print(f"[render_notebook] could not write {qmd_path}: {e}", file=sys.stderr)


def find_single_qmd(args):
    qmds = [a for a in args if a.endswith(".qmd") and os.path.isfile(a)]
    return qmds


def find_output_path(qmd_path, quarto_stdout_text):
    """Parse quarto's own `Output created: <path>` line (printed relative to the
    .qmd's directory, not the invocation cwd) rather than guessing quarto's
    output-path conventions (output-dir, project type, etc.)."""
    matches = re.findall(r"(?m)^Output created:\s*(.+)$", quarto_stdout_text)
    if not matches:
        return None
    raw = matches[-1].strip()
    return os.path.normpath(os.path.join(os.path.dirname(qmd_path), raw))


def html_block(fields):
    """Same fields as the .qmd markdown block, hand-formatted as raw HTML (no
    pandoc pass) so it can be spliced directly into an already-rendered page."""
    items = "\n".join(f"  <li>{k}: {v}</li>" for k, v in fields)
    return (
        f"<!-- render-env:start -->\n"
        f"<hr>\n"
        f'<h3 id="render-env-this-render">{HTML_MARKER}</h3>\n'
        f"<ul>\n{items}\n</ul>\n"
        f"<!-- render-env:end -->\n"
    )


def patch_html(html_path, block):
    """Insert or replace the managed block just before </body> in an already-
    rendered HTML file. Runs after quarto has fully finished -- this is plain
    text editing of a finished artifact, not a second render, so it can report
    accurate stats about the render that just produced this exact file."""
    try:
        with open(html_path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError as e:
        print(f"[render_notebook] could not read {html_path}: {e}", file=sys.stderr)
        return

    if HTML_BLOCK_RE.search(text):
        new_text = HTML_BLOCK_RE.sub(block, text)
    elif "</body>" in text:
        new_text = text.replace("</body>", block + "</body>", 1)
    else:
        new_text = text + "\n" + block

    if new_text == text:
        return
    try:
        with open(html_path, "w", encoding="utf-8") as f:
            f.write(new_text)
        print(f"[render_notebook] injected this-render stats into {html_path}")
    except OSError as e:
        print(f"[render_notebook] could not write {html_path}: {e}", file=sys.stderr)


HELP = """\
render_notebook — transparent shim over `quarto` that records the render
environment into a visible block.

USAGE
  Use it exactly like the quarto CLI — just swap `quarto` for `render_notebook`:
    render_notebook render notebook.qmd
    render_notebook render notebook.qmd --to pdf --output-dir out/

  All args pass straight through to quarto (output streams live as usual).
  After a successful render, if exactly one existing .qmd is among the args:
    - a block is inserted/updated at the end of the .qmd SOURCE. This always
      describes the PREVIOUS render, never the one that just ran -- a render's
      own timing/memory aren't known until quarto has already finished with
      the source file, so a render can't report on itself via the source.
    - if the output format is HTML, a SECOND block is injected directly into
      the just-produced HTML file (found via quarto's own "Output created:"
      line). This one IS accurate for the render that produced that file --
      it's a plain-text edit of a finished artifact, not a second quarto pass.
  Non-HTML formats (pdf, docx, ...) only get the source-side block, so they
  stay one render behind.

CAPTURED FIELDS
  last_rendered, host, node_type (compute/login/local), scheduler, slurm_job_id,
  partition, cpus_allocated, mem_allocated (Slurm grant), cpus_available,
  peak_rss (ACTUAL measured peak memory of the render), conda_env,
  quarto_version, render_args, elapsed.

  Use peak_rss to size the minimum memory for a re-render; mem_allocated is only
  what Slurm happened to grant. Read an existing notebook's blocks with:
    grep -A20 'render-env (auto-generated' notebook.qmd

NOTES
  - Only renders going through this wrapper are tagged (not `quarto preview`/IDE).
  - Blocks are written only on a successful (exit 0) render with a single .qmd.
  - A patch failure (either block) never changes quarto's exit code.
  - `render_notebook -h` shows this help; `render_notebook render nb.qmd --help`
    passes through to quarto's own help.
"""


def main():
    args = sys.argv[1:]
    if not args:
        print("usage: render_notebook <quarto args>   "
              "(e.g. render_notebook render notebook.qmd --to html)", file=sys.stderr)
        return 2

    if args[0] in ("-h", "--help"):
        print(HELP)
        return 0

    start = time.time()
    captured_lines = []
    try:
        # stdout+stderr merged into one pipe, streamed to the real stdout line by
        # line as it arrives (so live render progress is unaffected) while also
        # being captured so we can find quarto's own "Output created: <path>" line
        # afterward, without guessing quarto's output-path conventions.
        proc = subprocess.Popen(
            ["quarto"] + args,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
            text=True, bufsize=1,
        )
        for line in proc.stdout:
            sys.stdout.write(line)
            captured_lines.append(line)
        sys.stdout.flush()
        proc.wait()
        rc = proc.returncode
    except FileNotFoundError:
        print("[render_notebook] quarto not found on PATH", file=sys.stderr)
        return 127
    elapsed = time.time() - start
    quarto_output_text = "".join(captured_lines)

    # Peak RSS of the render child processes (Linux: KB, macOS: bytes).
    peak_rss_kb = None
    try:
        import resource
        ru = resource.getrusage(resource.RUSAGE_CHILDREN).ru_maxrss
        if ru > 0:
            peak_rss_kb = ru if sys.platform != "darwin" else ru / 1024
    except Exception:
        pass

    # Only patch on success, and only when exactly one .qmd is unambiguous.
    if rc == 0:
        qmds = find_single_qmd(args)
        if len(qmds) == 1:
            fields = collect_env(args, elapsed, peak_rss_kb)
            patch_qmd(qmds[0], render_block(fields))

            out_path = find_output_path(qmds[0], quarto_output_text)
            if out_path and out_path.lower().endswith(".html") and os.path.isfile(out_path):
                patch_html(out_path, html_block(fields))
            elif out_path and os.path.isfile(out_path):
                print(f"[render_notebook] output {out_path} is not HTML — "
                      f"this-render stats only available in the .qmd (next render).")
        elif len(qmds) == 0:
            print("[render_notebook] no single .qmd in args — skipping env block.")
        else:
            print(f"[render_notebook] multiple .qmd files {qmds} — skipping env block.")

    return rc


if __name__ == "__main__":
    sys.exit(main())
