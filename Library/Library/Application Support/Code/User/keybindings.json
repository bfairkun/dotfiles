// Place your key bindings in this file to override the defaults
[
  // For all languages
    {
        "key": "ctrl+v tab",
        "command": "type",
        "args": { "text": "\t" },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+shift+t",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "${relativeFile}" },
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+'",
        "command": "editor.action.smartSelect.grow",
        "when": "editorTextFocus"
    },
    {
      "key": "shift shift",
      "command": "editor.action.smartSelect.grow",
      "when": "editorTextFocus"
  },

  // For r/rmd
    {
      "key": "ctrl+alt+r",
      "description": "start tmux session with R for persistent session(s), per-workspace",
      "command": "runCommands",
      "args": {
        "commands": [
          {
            "command": "workbench.action.terminal.sendSequence",
            "args": {
              "text": "WS_ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; WS_NAME=\"$(basename \"$WS_ROOT\")\"; WS_NAME_SANITIZED=$(printf '%s' \"$WS_NAME\" | sed -E 's/[^A-Za-z0-9_.-]+/_/g'); tmux attach-session -t \"vscode_${WS_NAME_SANITIZED}_tmux_R\" || tmux new-session -s \"vscode_${WS_NAME_SANITIZED}_tmux_R\" R; printf '\\033]0;tmux.R:%s\\007' \"$WS_NAME_SANITIZED\"\n"
            }
          },
          {
            "command": "workbench.action.terminal.renameWithArg",
            "args": { "name": "tmux.R" }
          }
        ]
      },
      "when": "editorLangId =~ /r|rmd/"
    },
    {
      "key": "ctrl+cmd+enter",
      "command": "r.view"
    },
    {
    "key": "ctrl+alt+v",
    "description": "run View on selection",
    "command": "r.runCommandWithSelectionOrWord",
    "when": "editorLangId =~ /r|rmd/ && editorTextFocus",
    "args": "View($$)"
    },
    {
      "key": "ctrl+alt+t",
      "description": "Versatile hackish substitute for View(df) in VScode... See view_df_tsv in Rprofile. Nice to pair with excel viewer preview to view the tsv.",
      "command": "runCommands",
      "args": {
        "commands": [
          {
            "command": "r.runCommandWithSelectionOrWord",
            "args": "view_df_tsv($$)",
          },
          {
            "command": "workbench.action.tasks.runTask",
            "args": "Open TSV in VS Code"
          }
        ],
      },
      "when": "editorLangId =~ /r|rmd/ && editorTextFocus"
    },
    {
      "key": "ctrl+alt+e",
      "description": "Versatile hackish substitute for View(df) in VScode with excel viewer. I don't think this works... The intention is to get excel viewer preview to automatically open",
      "command": "runCommands",
      "args": {
        "commands": [
          {
            "command": "r.runCommandWithSelectionOrWord",
            "args": "view_df_tsv($$)",
          },
          {
            "command": "workbench.action.tasks.runTask",
            "args": "Open TSV in VS Code"
          },
          {
            "command": "excel.preview"
          }

        ],
      },
      "when": "editorLangId =~ /r|rmd/ && editorTextFocus"
    },
    {
      "key": "ctrl+alt+h",
      "description": "run head on selection",
      "command": "r.runCommandWithSelectionOrWord",
      "when": "editorLangId =~ /r|rmd/ && editorTextFocus",
      "args": "head($$, width=Inf)"
      },
    {
      "key": "ctrl+alt+p",
      "description": "bring up plot viewer",
      "command": "r.runCommand",
      "when": "editorTextFocus && editorLangId =~ /r|rmd/",
      "args": ".vsc.browser(httpgd::hgd_url(), viewer = \"Beside\")"
    },
    {
      "key": "cmd+alt+i",
      "description": "insert rmd chunk",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus && editorLangId =~ /r|rmd/",
      "args": {"snippet": "```{r}\n$0\n```"}
    },
    {
      "key": "cmd+alt+i",
      "description": "insert python chunk (quarto)",
      "command": "editor.action.insertSnippet",
      "when": "editorTextFocus && editorLangId == 'quarto'",
      "args": { "snippet": "```{python}\n$0\n```" }
    },
    {
      "key": "f1",
      "command": "r.helpPanel.openForSelection",
      "when": "editorTextFocus && editorLangId == 'r' || editorTextFocus && editorLangId =~ /r|rmd/"
    },
    {
      "key": "ctrl+alt+s",
      "command": "r.runCommandWithSelectionOrWord",
      "when": "editorTextFocus && editorLangId =~ /r|rmarkdown/",
      "args": "save_session()"
    },
    {
      "key": "ctrl+alt+l",
      "command": "r.runCommandWithSelectionOrWord",
      "when": "editorTextFocus && editorLangId =~ /r|rmarkdown/",
      "args": "load_session()"
    },
    {
      "key": "ctrl+shift", // still need to fix this regex
      "command": "selectbyregex.select",
      "args": {
          "regex": "[^\\n]*%>%[^\\n]*|[^\\n]*\\n",
          "selectAllMatches": false
      },
      "when": "editorTextFocus && editorLangId =~ /r|rmd/"
  }
]